# ─────────────────────────────────────────────────────────────────────
# NEXT.JS APPLICATION (.env.local)
# ─────────────────────────────────────────────────────────────────────
# These are used by the Next.js server (frontend & API routes).
# NO NEXT_PUBLIC_ prefix means they stay server-side only.

# Insforge Backend (server-side only — never exposed to browser)
INSFORGE_BASE_URL=https://e64sbexr.us-west.insforge.app
INSFORGE_ANON_KEY=your_insforge_anon_key_here

# VAPI Voice AI Integration (public key, safe to expose)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key_here

# ─────────────────────────────────────────────────────────────────────
# INSFORGE EDGE FUNCTIONS / BACKEND DENO RUNTIME
# ─────────────────────────────────────────────────────────────────────
# Set these in your Insforge project settings (or backend/.env)

# AkashML API (for chat completions)
AKASHML_API_KEY=your_akashml_api_key_here

# Ghost Database (PostgreSQL for conversation context)
GHOST_CONNECTION_STRING=postgresql://user:password@host:port/database

# Insforge runtime config (for edge functions)
ANON_KEY=your_insforge_anon_key_here

# TinyFish Web Research
TINYFISH_BASE_URL=https://api.tinyfish.ai/v1
TINYFISH_API_KEY=your_tinyfish_api_key_here
